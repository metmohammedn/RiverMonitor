# River Monitor — Environment Variables

# Debug mode (set to true for development)
DEBUG=false

# Server binding
HOST=0.0.0.0
PORT=8050

# Redis cache (optional — app runs without it)
REDIS_URL=redis://localhost:6379/0

# Data source (sqlite = archived, bom-api = live BoM Water API)
DATA_SOURCE=sqlite

# Google Analytics 4 (leave blank to disable)
GA_MEASUREMENT_ID=

# Open-Meteo API key (commercial subscription — leave blank for free tier)
# When set, automatically uses customer-*.open-meteo.com endpoints
OPENMETEO_API_KEY=

# Open-Meteo API endpoints (auto-configured based on API key, override if needed)
# OPENMETEO_FORECAST_URL=https://customer-api.open-meteo.com/v1/forecast
# OPENMETEO_MARINE_URL=https://customer-marine-api.open-meteo.com/v1/marine
# OPENMETEO_ENSEMBLE_URL=https://customer-ensemble-api.open-meteo.com/v1/ensemble

# API tuning
API_TIMEOUT=30
API_MAX_CONNECTIONS=10

# Gunicorn (production)
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
